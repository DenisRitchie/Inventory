#
# https://releases.llvm.org/22.1.0/tools/clang/docs/ClangFormatStyleOptions.html
# https://releases.llvm.org/22.1.0/tools/clang/docs/ClangFormatStyleOptions.html
#

---
# We'll use defaults from the LLVM style, but with 4 columns indentation.
BasedOnStyle: Microsoft
IndentWidth: 4
---
Language: Proto
# Don't format .proto files.
DisableFormat: true
---
Language: Cpp
AccessModifierOffset: -2
AlignAfterOpenBracket: true
AlignArrayOfStructures: Left # Right or Left
AlignConsecutiveAssignments:
  Enabled:          true
  AcrossEmptyLines: false
  AcrossComments:   false
  AlignCompound:    true
  PadOperators:     true
AlignConsecutiveBitFields:
  Enabled:          true
  AcrossEmptyLines: true
  AcrossComments:   false
AlignConsecutiveDeclarations:
  Enabled:                   true
  AcrossEmptyLines:          false
  AcrossComments:            false
  AlignFunctionDeclarations: true
  AlignFunctionPointers:     true
AlignConsecutiveMacros:
  Enabled:          true
  AcrossEmptyLines: false
  AcrossComments:   false
AlignConsecutiveShortCaseStatements:
  Enabled:          true
  AcrossEmptyLines: false
  AcrossComments:   false
  AlignCaseColons:  true
  AlignCaseArrows:  true
AlignConsecutiveTableGenBreakingDAGArgColons:
  Enabled:          true
  AcrossEmptyLines: false
  AcrossComments:   false
AlignConsecutiveTableGenCondOperatorColons:
  Enabled:          true
  AcrossEmptyLines: false
  AcrossComments:   false
AlignConsecutiveTableGenDefinitionColons:
  Enabled:          true
  AcrossEmptyLines: false
  AcrossComments:   false
AlignEscapedNewlines: Right # DontAlign, Left, LeftWithLastLine
AlignOperands: AlignAfterOperator # DontAlign, Align, AlignAfterOperator
AlignTrailingComments:
  Kind:            Always # Leave, Always, Never
  OverEmptyLines:  2
AllowAllArgumentsOnNextLine: false
# AllowAllConstructorInitializersOnNextLine: false
AllowAllParametersOfDeclarationOnNextLine: false
AllowBreakBeforeNoexceptSpecifier: OnlyWithParen # Never, OnlyWithParen, Always
AllowBreakBeforeQtProperty: false # clang-format 22
AllowShortBlocksOnASingleLine: Empty # Never, Empty, Always
AllowShortCaseExpressionOnASingleLine: true
AllowShortCaseLabelsOnASingleLine: true
AllowShortCompoundRequirementOnASingleLine: true
AllowShortEnumsOnASingleLine: true
AllowShortFunctionsOnASingleLine: Empty # None, Empty, InlineOnly, All
AllowShortIfStatementsOnASingleLine: Never # Never, WithoutElse, OnlyFirstIf, AllIfsAndElse
AllowShortLambdasOnASingleLine: All # None, Empty, Inline, All
AllowShortLoopsOnASingleLine: true
AllowShortNamespacesOnASingleLine: false
# AlwaysBreakAfterDefinitionReturnType: None # None, All, TopLevel
# AlwaysBreakAfterReturnType: true # Rename as BreakAfterReturnType
AlwaysBreakBeforeMultilineStrings: true
# AlwaysBreakTemplateDeclarations: true # Rename as BreakTemplateDeclarations
AttributeMacros: [__capability, __output, __unused] # List of macros that are used as attributes. The formatter will try to keep them attached to the declaration they belong to.
BinPackArguments: false
BinPackLongBracedList: true
BinPackParameters: OnePerLine # BinPack, OnePerLine, AlwaysOnePerLine
BitFieldColonSpacing: Both # None, Before, After, Both
BreakBeforeBraces: Custom
BraceWrapping:
  AfterCaseLabel:        true
  AfterClass:            true
  AfterControlStatement: true # Never, Always, MultiLine
  AfterEnum:             true
  AfterFunction:         true
  AfterNamespace:        true
  AfterObjCDeclaration:  true
  AfterStruct:           true
  AfterUnion:            true
  AfterExternBlock:      true
  BeforeCatch:           true
  BeforeElse:            true
  BeforeLambdaBody:      false
  BeforeWhile:           true
  IndentBraces:          false
  SplitEmptyFunction:    true
  SplitEmptyRecord:      true
  SplitEmptyNamespace:   true
BracedInitializerIndentWidth: 2
BreakAdjacentStringLiterals: true
BreakAfterAttributes: Leave # Leave, Always, Never
BreakAfterJavaFieldAnnotations: false
BreakAfterOpenBracketBracedList: true
BreakAfterOpenBracketFunction: true
BreakAfterOpenBracketIf: true
BreakAfterOpenBracketLoop: true
BreakAfterOpenBracketSwitch: true
BreakAfterReturnType: Automatic # TopLevel, AllDefinitions, TopLevelDefinitions
BreakArrays: false
BreakBeforeBinaryOperators: NonAssignment # None, NonAssignment, All
BreakBeforeCloseBracketBracedList: true
BreakBeforeCloseBracketFunction: true
BreakBeforeCloseBracketIf: true
BreakBeforeCloseBracketLoop: true
BreakBeforeCloseBracketSwitch: true
BreakBeforeConceptDeclarations: Always # Always, Allowed, Never
BreakBeforeInlineASMColon: OnlyMultiline # Never, OnlyMultiline, Always
BreakBeforeTemplateCloser: true
BreakBeforeTernaryOperators: true
BreakBinaryOperations: Never # Never, OnePerLine, RespectPrecedence
BreakConstructorInitializers: BeforeComma # BeforeComma, BeforeColon, AfterColon
BreakFunctionDefinitionParameters: false
BreakInheritanceList: BeforeComma # BeforeColon, BeforeComma, AfterColon, AfterComma
BreakStringLiterals: false
BreakTemplateDeclarations: Leave # Leave, No, MultiLine, Yes
ColumnLimit: 250
# CommentPragmas: '^ FOOBAR pragma:' # Regular expression matching comments that should be left alone by clang-format.
CompactNamespaces: false
# ConstructorInitializerAllOnOneLineOrOnePerLine: true # Deprecated, use PackConstructorInitializers instead.
ConstructorInitializerIndentWidth: 2
ContinuationIndentWidth: 4
Cpp11BracedListStyle: Block # Block, FunctionCall, AlignFirstComment
# DeriveLineEnding: true # This option is deprecated. See DeriveLF and DeriveCRLF of LineEnding.
DerivePointerAlignment: false
DisableFormat: false
EmptyLineAfterAccessModifier: Leave # Never, Always, Leave
EmptyLineBeforeAccessModifier: Always # Never, Always, Leave, LogicalBlock
EnumTrailingComma: Remove # Leave, Insert, Remove
ExperimentalAutoDetectBinPacking: true
FixNamespaceComments: true
ForEachMacros: [RANGES_FOR, FOREACH] # List of macros that should be interpreted as foreach loops. The formatter will try to format them like a C++11 range-based for loop.
IfMacros: [IF] # List of macros that should be interpreted as if statements. The formatter will try to format them like if statements.
IncludeBlocks: Regroup # Regroup, Merge, Preserve
# IncludeCategories:
#   - Regex:           '^"(llvm|llvm-c|clang|clang-c)/'
#     Priority:        2
#     SortPriority:    2
#     CaseSensitive:   true
#   - Regex:           '^((<|")(gtest|gmock|isl|json)/)'
#     Priority:        3
#   - Regex:           '<[[:alnum:].]+>'
#     Priority:        4
#   - Regex:           '.*'
#     Priority:        1
#     SortPriority:    0
# IncludeIsMainRegex: '^"([^/]+/)?$FILENAME$"' # Regular expression matching the main file being formatted. The formatter will try to keep it as the first include.
# IncludeIsMainSourceRegex: '^"([^/]+/)?$FILENAME_NO_EXT$\.(cpp|c|cc|cxx|m|mm|ino)$"' # Regular expression matching the main source file being formatted. The formatter will try to keep it as the first include.
IndentAccessModifiers: false
IndentCaseBlocks: false
IndentCaseLabels: true
IndentExternBlock: AfterExternBlock # AfterExternBlock, NoIndent, Indent
IndentGotoLabels: true
IndentPPDirectives: Leave # None, BeforeHash, AfterHash, Leave
IndentRequiresClause: true
IndentWrappedFunctionNames: true
InsertBraces: true
InsertNewlineAtEOF: true
InsertTrailingCommas: None # None, Wrapped
IntegerLiteralSeparator:
  Binary:  4
  Hex:    -1
  Decimal: 3
JavaImportGroups: [com.example, com, org]
JavaScriptQuotes: Double # Leave, Single, Double
JavaScriptWrapImports: true
KeepEmptyLines:
  AtEndOfFile:    false
  AtStartOfBlock: false
  AtStartOfFile:  false
# KeepEmptyLinesAtEOF: true # This option is deprecated. See AtEndOfFile of KeepEmptyLines.
# KeepEmptyLinesAtTheStartOfBlocks: false # This option is deprecated. See AtStartOfBlock of KeepEmptyLines.
KeepFormFeed: true
LambdaBodyIndentation: Signature # Signature, OuterScope
LineEnding: DeriveCRLF # LF, CRLF, CR, DeriveCRLF, DeriveLF
# MacroBlockBegin: "^NS_MAP_BEGIN|\
# NS_TABLE_HEAD$"
# MacroBlockEnd: "^\
# NS_MAP_END|\
# NS_TABLE_.*_END$"
# Macros: (List of Strings) A list of macros of the form <definition>=<expansion>.
# MacrosSkippedByRemoveParentheses: [BOOST_PP_CAT] # A vector of function-like macros whose invocations should be skipped by RemoveParentheses.
# MainIncludeChar: Any # Any, AngleBracket, Quote
MaxEmptyLinesToKeep: 1
NamespaceIndentation: All # None, Inner, All
NamespaceMacros: [NS_BEGIN, NS_END, NAMESPACE, TESTSUITE] # List of macros that should be interpreted as namespace definitions. The formatter will try to format them like normal namespaces.
NumericLiteralCase:
  ExponentLetter: Leave # Leave, Upper, Lower
  HexDigit:       Upper # Leave, Upper, Lower
  Prefix:         Lower # Leave, Upper, Lower
  Suffix:         Upper # Leave, Upper, Lower
ObjCBinPackProtocolList: Auto # Auto, Always, Never
ObjCBlockIndentWidth: 4
ObjCBreakBeforeNestedBlockParam: false
ObjCPropertyAttributeOrder: [
    class, direct,
    atomic, nonatomic,
    assign, retain, strong, copy, weak, unsafe_unretained,
    readonly, readwrite, getter, setter,
    nullable, nonnull, null_resettable, null_unspecified
]
ObjCSpaceAfterProperty: false
ObjCSpaceBeforeProtocolList: true
OneLineFormatOffRegex: ^(// NOLINT|logger$)
PPIndentWidth: 2
PackConstructorInitializers: BinPack # Never, BinPack, CurrentLine, NextLine, NextLineOnly
# Begin Penalties Keys: A list of penalties that will be used to rank formatting options. The formatter will prefer formatting options with lower penalties. The default values are chosen to produce the same formatting as clang-format 10.0.0.
PenaltyBreakAssignment: 50
PenaltyBreakBeforeFirstCallParameter: 30
PenaltyBreakBeforeMemberAccess: 150
PenaltyBreakComment: 10
PenaltyBreakFirstLessLess: 120
PenaltyBreakOpenParenthesis: 40
PenaltyBreakScopeResolution: 200
PenaltyBreakString: 20
PenaltyBreakTemplateDeclaration: 10
PenaltyExcessCharacter: 100
PenaltyIndentedWhitespace: 5
PenaltyReturnTypeOnItsOwnLine: 60
# End Penalties Keys
PointerAlignment: Left # Left, Right, Middle
QualifierAlignment: Custom # Leave, Left, Right, Custom
QualifierOrder: [friend, static, inline, constexpr, const, volatile, type]
RawStringFormats:
  - Language: Json
    Delimiters:
      - json
      - JSON
    BasedOnStyle: LLVM
    CanonicalDelimiter: json

  - Language: Cpp
    Delimiters:
      - cpp
      - Cpp
    BasedOnStyle: LLVM
    CanonicalDelimiter: cpp
ReferenceAlignment: Left # Left, Right, Middle
ReflowComments: IndentOnly # Never, IndentOnly, Always
RemoveBracesLLVM: false
RemoveEmptyLinesInUnwrappedLines: true
RemoveParentheses: MultipleParentheses # Leave, MultipleParentheses, ReturnStatement
RemoveSemicolon: true
RequiresClausePosition: OwnLine # OwnLine, OwnLineWithBrace, WithPreceding, WithFollowing, SingleLine
RequiresExpressionIndentation: OuterScope # OuterScope, Keyword
SeparateDefinitionBlocks: Always # Always, Never, Leave
ShortNamespaceLines: 1
SkipMacroDefinitionBody: true
SortIncludes: false # Enabled, IgnoreCase, IgnoreExtension
SortJavaStaticImport: After # After, Before
SortUsingDeclarations: Lexicographic # None, Lexicographic, LexicographicNumeric
SpaceAfterCStyleCast: false
SpaceAfterLogicalNot: false
SpaceAfterOperatorKeyword: false
SpaceAfterTemplateKeyword: false
SpaceAroundPointerQualifiers: Before # Default, Before, After, Both
SpaceBeforeAssignmentOperators: true
SpaceBeforeCaseColon: false
SpaceBeforeCpp11BracedList: true
SpaceBeforeCtorInitializerColon: true
SpaceBeforeInheritanceColon: true
SpaceBeforeJsonColon: false
SpaceBeforeParens: Custom # Never, ControlStatements, ControlStatementsExceptControlMacros, NonEmptyParentheses, Always, Custom
SpaceBeforeParensOptions:
  AfterControlStatements:       true
  AfterForeachMacros:           true
  AfterFunctionDeclarationName: false
  AfterFunctionDefinitionName:  false
  AfterIfMacros:                true
  AfterNot:                     true
  AfterOverloadedOperator:      false
  AfterPlacementOperator:       true
  AfterRequiresInClause:        true
  AfterRequiresInExpression:    true
  BeforeNonEmptyParentheses:    false
SpaceBeforeRangeBasedForLoopColon: true
SpaceBeforeSquareBrackets: false
# SpaceInEmptyBlock: true # This option is deprecated. See Block of SpaceInEmptyBraces.
SpaceInEmptyBraces: Always # Always, Block, Never
# SpaceInEmptyParentheses: false # If true, spaces may be inserted into (). This option is deprecated. See InEmptyParentheses of SpacesInParensOptions.
SpacesBeforeTrailingComments: 3
SpacesInAngles: Leave # Never, Always, Leave
# SpacesInCStyleCastParentheses: false # If true, spaces may be inserted into C style casts. This option is deprecated. See InCStyleCasts of SpacesInParensOptions.
# SpacesInConditionalStatement: true # If true, spaces will be inserted around if/for/switch/while conditions. This option is deprecated. See InConditionalStatements of SpacesInParensOptions.
SpacesInContainerLiterals: true
SpacesInLineCommentPrefix:
  Minimum:  1
  Maximum: -1
SpacesInParens: Custom # Never, Custom
SpacesInParensOptions:
  ExceptDoubleParentheses: false
  InConditionalStatements: true
  InCStyleCasts:           false
  InEmptyParentheses:      false
  Other:                   false
# SpacesInParentheses: false # If true, spaces will be inserted after ( and before ). This option is deprecated. The previous behavior is preserved by using SpacesInParens with Custom and by setting all SpacesInParensOptions to true except for InCStyleCasts and InEmptyParentheses.
SpacesInSquareBrackets: false
Standard: Latest # c++03, c++11, c++14, c++17, c++20, Latest, Auto
StatementAttributeLikeMacros: []
StatementMacros: [Q_UNUSED] # List of macros that should be interpreted as statement attributes. The formatter will try to format them like normal statement attributes.
TabWidth: 4
TableGenBreakInsideDAGArg: BreakAll # DontBreak, BreakElements, BreakAll
TableGenBreakingDAGArgOperators: [ins, outs]
TemplateNames: []
TypeNames: []
TypenameMacros: [STACK_OF, LIST]
# UseCRLF: true # This option is deprecated. See LF and CRLF of LineEnding.
UseTab: Never # Never, ForIndentation, ForContinuationAndIndentation, AlignWithSpaces, Always
VariableTemplates: []
VerilogBreakBetweenInstancePorts: false
WhitespaceSensitiveMacros: [STRINGIZE, PP_STRINGIZE, BOOST_PP_STRINGIZE]
WrapNamespaceBodyWithEmptyLines: Leave # Never, Always, Leave
...
